generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  TEACHER
  STUDENT
}

enum UserStatus {
  ACTIVE
  LOCKED
}

enum Difficulty {
  EASY
  MEDIUM
  HARD
}

enum CorrectAnswer {
  A
  B
  C
  D
}

enum ExamStatus {
  DRAFT
  PUBLISHED
  CLOSED
}

enum AttemptStatus {
  IN_PROGRESS
  SUBMITTED
}

enum ExamVisibility {
  PUBLIC
  PRIVATE
}

model User {
  id           Int        @id @default(autoincrement())
  fullName     String     @map("full_name")
  email        String     @unique
  passwordHash String     @map("password_hash")
  role         Role
  status       UserStatus @default(ACTIVE)
  avatarUrl    String?    @map("avatar_url")
  schoolName   String?    @map("school_name")
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")

  passwordResetToken   String?   @map("password_reset_token")
  passwordResetExpires DateTime? @map("password_reset_expires")

  questions               Question[]
  exams                   Exam[]
  attempts                ExamAttempt[]
  assignedExams           ExamStudent[]
  teachingSubjects        TeacherSubject[] @relation("TeacherAssignments")
  assignedTeacherSubjects TeacherSubject[] @relation("TeacherSubjectAssignedBy")

  // Classroom relations
  teachingClassrooms Classroom[]    @relation("ClassroomTeacher")
  enrolledClassrooms ClassStudent[]

  @@map("users")
}

enum ClassroomStatus {
  ACTIVE
  ARCHIVED
}

model Classroom {
  id          Int             @id @default(autoincrement())
  name        String
  code        String          @unique
  description String?
  schoolName  String?         @map("school_name")
  bannerUrl   String?         @map("banner_url")
  status      ClassroomStatus @default(ACTIVE)
  teacherId   Int             @map("teacher_id")
  subjectId   Int             @map("subject_id")
  createdAt   DateTime        @default(now()) @map("created_at")
  updatedAt   DateTime        @updatedAt @map("updated_at")

  teacher  User            @relation("ClassroomTeacher", fields: [teacherId], references: [id], onDelete: Cascade)
  subject  Subject         @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  students ClassStudent[]
  exams    ExamClassroom[]

  @@map("classrooms")
}

model ClassStudent {
  id          Int      @id @default(autoincrement())
  classroomId Int      @map("classroom_id")
  studentId   Int      @map("student_id")
  joinedAt    DateTime @default(now()) @map("joined_at")

  classroom Classroom @relation(fields: [classroomId], references: [id], onDelete: Cascade)
  student   User      @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([classroomId, studentId])
  @@map("class_students")
}

model ExamClassroom {
  id          Int      @id @default(autoincrement())
  examId      Int      @map("exam_id")
  classroomId Int      @map("classroom_id")
  assignedAt  DateTime @default(now()) @map("assigned_at")

  exam      Exam      @relation(fields: [examId], references: [id], onDelete: Cascade)
  classroom Classroom @relation(fields: [classroomId], references: [id], onDelete: Cascade)

  @@unique([examId, classroomId])
  @@map("exam_classrooms")
}

model Subject {
  id          Int      @id @default(autoincrement())
  name        String
  code        String   @unique
  description String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  questions          Question[]
  exams              Exam[]
  teacherAssignments TeacherSubject[]
  classrooms         Classroom[]

  @@map("subjects")
}

model Question {
  id            Int           @id @default(autoincrement())
  subjectId     Int           @map("subject_id")
  createdById   Int           @map("created_by")
  content       String
  optionA       String        @map("option_a")
  optionB       String        @map("option_b")
  optionC       String        @map("option_c")
  optionD       String        @map("option_d")
  correctAnswer CorrectAnswer @map("correct_answer")
  difficulty    Difficulty    @default(EASY)
  defaultPoint  Decimal       @default(1.0) @map("default_point")
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")

  subject        Subject         @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  createdBy      User            @relation(fields: [createdById], references: [id], onDelete: Cascade)
  examQuestions  ExamQuestion[]
  studentAnswers StudentAnswer[]

  @@map("questions")
}

model TeacherSubject {
  id           Int      @id @default(autoincrement())
  teacherId    Int      @map("teacher_id")
  subjectId    Int      @map("subject_id")
  assignedById Int?     @map("assigned_by")
  note         String?
  assignedAt   DateTime @default(now()) @map("assigned_at")

  teacher    User    @relation("TeacherAssignments", fields: [teacherId], references: [id], onDelete: Cascade)
  subject    Subject @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  assignedBy User?   @relation("TeacherSubjectAssignedBy", fields: [assignedById], references: [id], onDelete: SetNull)

  @@unique([teacherId, subjectId])
  @@map("teacher_subjects")
}

model Exam {
  id                 Int            @id @default(autoincrement())
  subjectId          Int            @map("subject_id")
  createdById        Int            @map("created_by")
  title              String
  description        String?
  durationMinutes    Int            @map("duration_minutes")
  passPercentage     Int            @default(50) @map("pass_percentage")
  startTime          DateTime?      @map("start_time")
  endTime            DateTime?      @map("end_time")
  status             ExamStatus     @default(DRAFT)
  visibility         ExamVisibility @default(PRIVATE)
  accessPasswordHash String?        @map("access_password_hash")
  createdAt          DateTime       @default(now()) @map("created_at")
  updatedAt          DateTime       @updatedAt @map("updated_at")

  subject            Subject         @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  createdBy          User            @relation(fields: [createdById], references: [id], onDelete: Cascade)
  examQuestions      ExamQuestion[]
  attempts           ExamAttempt[]
  assignedStudents   ExamStudent[]
  assignedClassrooms ExamClassroom[]

  @@map("exams")
}

model ExamQuestion {
  id            Int     @id @default(autoincrement())
  examId        Int     @map("exam_id")
  questionId    Int     @map("question_id")
  questionOrder Int?    @map("question_order")
  point         Decimal @default(1.0)

  exam     Exam     @relation(fields: [examId], references: [id], onDelete: Cascade)
  question Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([examId, questionId])
  @@map("exam_questions")
}

model ExamStudent {
  id         Int      @id @default(autoincrement())
  examId     Int      @map("exam_id")
  studentId  Int      @map("student_id")
  assignedAt DateTime @default(now()) @map("assigned_at")

  exam    Exam @relation(fields: [examId], references: [id], onDelete: Cascade)
  student User @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([examId, studentId])
  @@map("exam_students")
}

model ExamAttempt {
  id             Int           @id @default(autoincrement())
  examId         Int           @map("exam_id")
  studentId      Int           @map("student_id")
  startedAt      DateTime      @default(now()) @map("started_at")
  submittedAt    DateTime?     @map("submitted_at")
  totalQuestions Int           @default(0) @map("total_questions")
  correctCount   Int           @default(0) @map("correct_count")
  score          Decimal       @default(0)
  tabFocusLosses Int           @default(0) @map("tab_focus_losses")
  status         AttemptStatus @default(IN_PROGRESS)

  exam    Exam            @relation(fields: [examId], references: [id], onDelete: Cascade)
  student User            @relation(fields: [studentId], references: [id], onDelete: Cascade)
  answers StudentAnswer[]

  @@map("exam_attempts")
}

model SystemSetting {
  id                 Int      @id @default(1)
  siteName           String   @default("Examify Assessment Engine") @map("site_name")
  contactEmail       String   @default("support@examify.com") @map("contact_email")
  registrationOpen   Boolean  @default(true) @map("registration_open")
  proctoringEnforced Boolean  @default(true) @map("proctoring_enforced")
  tabFocusWarnings   Int      @default(3) @map("tab_focus_warnings")
  updatedAt          DateTime @updatedAt @map("updated_at")

  @@map("system_settings")
}

model StudentAnswer {
  id             Int            @id @default(autoincrement())
  attemptId      Int            @map("attempt_id")
  questionId     Int            @map("question_id")
  selectedAnswer CorrectAnswer? @map("selected_answer")
  isCorrect      Boolean        @default(false) @map("is_correct")

  attempt  ExamAttempt @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  question Question    @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([attemptId, questionId])
  @@map("student_answers")
}
